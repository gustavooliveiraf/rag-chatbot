# OpenAI API key, used for both gpt-5-mini generation and text-embedding-3-small embeddings
OPENAI_API_KEY=

# Postgres connection string (defaults match docker-compose.yml)
DATABASE_URL=postgres://rag:rag@localhost:5432/vtex_rag_chatbot

# HTTP port for the API
PORT=3000

# Model ids (centralized here so they can be swapped without a code change)
GENERATION_MODEL=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small

# Retrieval tuning
RETRIEVAL_TOP_K=5
# Fixed cosine-similarity decline threshold (FR-004): passages scoring below this
# are excluded from context; if none remain, the system declines to answer.
RETRIEVAL_SIMILARITY_THRESHOLD=0.75
